# Telegram bot token from @BotFather
TELOXIDE_TOKEN=your_bot_token_here

# Log level (optional)
RUST_LOG=info

# TikTok download API URL (optional, has default)
# TIKWM_API_URL=https://www.tikwm.com/api/

# Security: Authorized user IDs (comma-separated, empty = allow all)
# AUTHORIZED_USERS=123456789,987654321

# Security: Authorized chat IDs (comma-separated, empty = allow all)
# AUTHORIZED_CHATS=-1001234567890
